{
  "cli": {
    "version": ">= 19.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_USE_EMULATOR": "true" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "environment": "preview",
      "env": { "EXPO_PUBLIC_USE_EMULATOR": "false" }
    },
    "production": {
      "environment": "production",
      "env": { "EXPO_PUBLIC_USE_EMULATOR": "false" }
    }
  },
  "submit": {
    "production": {}
  }
}
