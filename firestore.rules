rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can create their own document but only as 'customer', never as 'admin'
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == 'customer';
      // Users can update their own document but cannot change role or createdAt
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdAt']);
    }

    match /menu/{itemId} {
      // Public so guests can browse the menu before signing in
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false;
      allow update: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin-only config (e.g. Clip terminal serial). NOT publicly readable like settings/*.
    match /config/{document} {
      allow read, write: if isAdmin();
    }
  }
}
