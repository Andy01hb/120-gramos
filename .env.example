# Copia este archivo como .env.local (desarrollo) o .env.production (produccion)
# Encuentra los valores en: Firebase Console -> Configuracion del proyecto -> Tus apps

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Stripe -> Dashboard -> Developers -> API keys (usa pk_test_... para pruebas)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# true = conecta al emulador local | false = usa Firebase real
EXPO_PUBLIC_USE_EMULATOR=true
