{
  "name": "120-gramos-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@stripe/stripe-react-native": "^0.66.0",
    "expo": "~56.0.4",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-notifications": "~56.0.13",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "^56.0.10",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.12",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "EXPO_ENV=local expo start --env-file .env.local",
    "emulator": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "emulator:clean": "firebase emulators:start",
    "build:web": "npx expo export --platform web",
    "deploy:web": "npm run build:web && vercel dist/ --yes --prod",
    "build:preview": "eas build -p android --profile preview",
    "build:prod": "eas build -p android --profile production"
  },
  "private": true
}
