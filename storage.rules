rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admin gate via custom claim (set by the syncAdminClaim function + initial seed).
    // Storage→Firestore cross-service lookups proved unreliable in this project,
    // so we read the claim straight from the auth token.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /menu/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /banners/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /home/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
